# ============================================================
# _TripartiteDataSTORE - Git Ignore Rules
# ============================================================

# ── Python Runtime & Caches ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.coverage
.coverage.*
htmlcov/

# ── Virtual Environments ───────────────────────────────────────
.venv/
venv/
ENV/
env/
.conda/
.condarc
pip-wheel-metadata/

# ── Build & Distribution ───────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/
pip-log.txt
*.whl

# ── IDE & Editors ──────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.swp
*~
.DS_Store

# ── Operating System ───────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ── Application Data (Generated) ───────────────────────────────
# SQLite databases
_db/
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal
*.wal
*.shm

# JSONL session/memory files
*.jsonl
memory_archive_*.jsonl
working_memory*.jsonl
session_*.jsonl

# Logs & temp files
*.log
*.tmp
*.temp
.cache/
_logs/

# ── Secrets & Local Config ─────────────────────────────────────
.env
.env.*
*.env
secrets.json
config.local.json
app_config.json
app_config.json.tmp

# ── Vector & Knowledge Base Stores ─────────────────────────────
knowledge_base/
chroma/
chromadb/
vector_store/
vectors/
*.faiss
*.index

# ── Model Files (Large) ────────────────────────────────────────
# Uncomment to exclude GGUF models from git (they're large!)
# *.gguf
# models/
# embeddings/

# ── Jupyter / Notebooks ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Optional: Project Reports/Maps ─────────────────────────────
# Uncomment if you generate these frequently and don't want them in git
# *_project_map.txt
# *_filedump.txt
# *_folder_tree.txt

# ── Tree-sitter Generated Files ────────────────────────────────
# Language grammars are installed via pip, no need to commit
# If you manually build grammars, uncomment:
# tree-sitter-*.so
# tree-sitter-*.dylib
# tree-sitter-*.dll

# ── Test Output ────────────────────────────────────────────────
test_output/
test_*.db
coverage.xml
.tox/

# ── Documentation Builds ───────────────────────────────────────
docs/_build/
docs/.doctrees/
site/

# ══════════════════════════════════════════════════════════════
# Project-Specific Exceptions
# ══════════════════════════════════════════════════════════════

# DO commit these documentation/config files:
!README.md
!requirements.txt
!setup_env.bat
!setup_env.sh
!.gitignore
!LICENSE.md
!pyproject.toml
!tripartite.spec

# DO commit the treesitter integration package:
!treesitter_integration/
!treesitter_integration/**

# DO commit example/test files if needed:
!tests/
!tests/**
